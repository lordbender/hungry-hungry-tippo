    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jose": "^5.10.0",
    "pg": "^8.16.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.30",
    "@types/pg": "^8.15.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
